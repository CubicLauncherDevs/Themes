        "zipName": "Notstaff_Chill.cbth",
        "dirPath": "src/Notstaff/chill/V1",
        "date": "2026-07-14T23:15:10-06:00",
        "changelog": "# V1\n\n- Lanzamiento inicial\n- Tema chill con tonos fríos azulados y teal\n"
      }
    ],
    "latestVersion": "V1",
    "previewUrl": "https://raw.githubusercontent.com/CubicLauncherDevs/Themes/master/src/Notstaff/chill/V1/Showcase.png",
    "zipUrl": "https://raw.githubusercontent.com/CubicLauncherDevs/Themes/master/src/Notstaff/chill/V1/Notstaff_Chill.cbth",
    "zipName": "Notstaff_Chill.cbth",
